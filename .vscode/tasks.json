{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Django Make Migrations",
      "type": "shell",
      "detail": "Make migrations for django app.",
      "command": "${config:python.defaultInterpreterPath}",
      "args": [
        "manage.py",
        "makemigrations"
      ],
      // just skip prompt for matchers
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}"
      },
    },
    {
      "label": "Django Migrate",
      "type": "shell",
      "detail": "Apply migrations for whole django project.",
      "command": "${config:python.defaultInterpreterPath}",
      "args": [
        "manage.py",
        "migrate",
      ],
      // just skip prompt for matchers
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}"
      },
    },
    {
      "label": "Pytest",
      "type": "shell",
      "command": "pytest --timeout=10 tests",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "Pytest (changed tests only)",
      "type": "shell",
      "command": "pytest --timeout=10 --picked",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "Ruff",
      "type": "shell",
      "command": "uvx ruff format && uvx ruff check --fix",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "Pylint",
      "type": "shell",
      "command": "pylint glad --output-format=colorized --disable=R0903",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "Code Coverage",
      "detail": "Generate code coverage report.",
      "type": "shell",
      "command": "pytest --cov --cov-report term-missing --durations-min=1 --durations=0",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "Install all requirements",
      "type": "shell",
      "command": "uv sync --frozen --active",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    }
  ]
}
