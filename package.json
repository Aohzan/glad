{
  "name": "glad-vendors",
  "version": "1.0.0",
  "private": true,
  "description": "Frontend vendor dependencies for Glad. Run `npm ci` to install and populate static/vendors/.",
  "scripts": {
    "postinstall": "vendor-copy"
  },
  "dependencies": {
    "@wernfried/daterangepicker": "5.3.7",
    "apexcharts": "5.10.6",
    "bootstrap": "5.3.6",
    "bootstrap-icons": "1.11.0",
    "simple-datatables": "^10.2.0",
    "leaflet": "1.9.4",
    "luxon": "3.7.2",
    "multi-select-dropdown-js": "^1.0.3"
  },
  "devDependencies": {
    "vendor-copy": "3.0.1"
  },
  "vendorCopy": [
    {
      "from": "node_modules/bootstrap/dist/css/bootstrap.min.css",
      "to": "static/vendors/bootstrap/bootstrap.min.css"
    },
    {
      "from": "node_modules/bootstrap/dist/css/bootstrap.min.css.map",
      "to": "static/vendors/bootstrap/bootstrap.min.css.map"
    },
    {
      "from": "node_modules/bootstrap/dist/js/bootstrap.bundle.min.js",
      "to": "static/vendors/bootstrap/bootstrap.bundle.min.js"
    },
    {
      "from": "node_modules/bootstrap/dist/js/bootstrap.bundle.min.js.map",
      "to": "static/vendors/bootstrap/bootstrap.bundle.min.js.map"
    },
    {
      "from": "node_modules/bootstrap-icons/font",
      "to": "static/vendors/bootstrap-icons/font"
    },
    {
      "from": "node_modules/apexcharts/dist/apexcharts.min.js",
      "to": "static/vendors/apexcharts/apexcharts.min.js"
    },
    {
      "from": "node_modules/leaflet/dist/leaflet.css",
      "to": "static/vendors/leaflet/leaflet.css"
    },
    {
      "from": "node_modules/leaflet/dist/leaflet.js",
      "to": "static/vendors/leaflet/leaflet.js"
    },
    {
      "from": "node_modules/leaflet/dist/leaflet.js.map",
      "to": "static/vendors/leaflet/leaflet.js.map"
    },
    {
      "from": "node_modules/leaflet/dist/images",
      "to": "static/vendors/leaflet/images"
    },
    {
      "from": "node_modules/simple-datatables/dist/umd/simple-datatables.js",
      "to": "static/vendors/simple-datatables/simple-datatables.js"
    },
    {
      "from": "node_modules/simple-datatables/dist/style.css",
      "to": "static/vendors/simple-datatables/simple-datatables.css"
    },
    {
      "from": "node_modules/luxon/build/global/luxon.min.js",
      "to": "static/vendors/luxon/luxon.min.js"
    },
    {
      "from": "node_modules/@wernfried/daterangepicker/dist/global/daterangepicker.min.js",
      "to": "static/vendors/daterangepicker/daterangepicker.min.js"
    },
    {
      "from": "node_modules/@wernfried/daterangepicker/dist/global/daterangepicker.min.js.map",
      "to": "static/vendors/daterangepicker/daterangepicker.min.js.map"
    },
    {
      "from": "node_modules/@wernfried/daterangepicker/css/daterangepicker.min.css",
      "to": "static/vendors/daterangepicker/daterangepicker.min.css"
    },
    {
      "from": "node_modules/multi-select-dropdown-js/MultiSelect.min.css",
      "to": "static/vendors/multi-select-dropdown-js/MultiSelect.min.css"
    },
    {
      "from": "node_modules/multi-select-dropdown-js/MultiSelect.min.js",
      "to": "static/vendors/multi-select-dropdown-js/MultiSelect.min.js"
    }
  ]
}
